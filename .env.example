# Azure OpenAI API ключ (обязательно для boss и worker сервисов)
AZURE_API_KEY=your-azure-api-key-here

# Database connection string (для локальной разработки)
DB_DNS=host=localhost user=postgres password=postgres dbname=crewai port=5432

# Redis connection string (для WebSocket стримов и кэширования)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# JWT Secrets для аутентификации
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-refresh-secret-here

# Worker mode: multypass (optimized, -45% tokens) | nplus1 (legacy)
WORKER_MODE=multypass

# Frontend URLs (relative paths, nginx proxies to services)
# For local dev (Vite): VITE_AUTH_URL=http://localhost:3112

# ===========================================
# Rate Limiting (apigateway)
# ===========================================
# Формат: запросы/секунды (например 10/60 = 10 запросов за 60 секунд)
RATE_LIMIT_ENABLED=true
# Создание задач — самый строгий лимит (тяжёлая операция)
RATE_LIMIT_TASK_CREATE=10/60
# Статус задачи — лёгкая операция, можно чаще
RATE_LIMIT_TASK_STATUS=60/60
# Переподключение к задаче
RATE_LIMIT_TASK_RECONNECT=30/60
# Health check — можно часто
RATE_LIMIT_HEALTH=120/60
